# PostgreSQL
DATABASE_URL=

# JWT
JWT_SECRET=change-me-in-production-use-at-least-32-chars
JWT_TTL=24h

# S3-compatible storage (MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=amigos-proofs
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Server
PORT=8080
API_BASE_PATH=/v1

# Ticket number prefix
TICKET_PREFIX=40% OHHR-VOL.2

# Seed admin (used by: make seed)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
